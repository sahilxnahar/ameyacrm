// ════════════════════════════════════════════════════════════════════════════
//  Ameya Heights CRM — Prisma schema
//  Construction + Real-Estate ERP-lite. Multi-project, multi-department, RBAC.
//  Designed for PostgreSQL. All IDs are cuid; all tables carry audit timestamps.
// ════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum RoleName {
  SUPER_ADMIN
  ADMIN
  DEPARTMENT_HEAD
  MANAGER
  EXECUTIVE
  EMPLOYEE
  READ_ONLY
  GUEST
}

enum UserStatus {
  INVITED
  PENDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum AssigneeState {
  ASSIGNED
  ACCEPTED
  REJECTED
  CLARIFICATION_REQUESTED
  COMPLETED
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT
  NEGOTIATION
  BOOKED
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  WALK_IN
  CAMPAIGN
  PORTAL
  NRI_DESK
  BROKER
  OTHER
}

enum LeadActivityType {
  CALL
  MEETING
  NOTE
  SITE_VISIT
  EMAIL
  WHATSAPP
  DOCUMENT
}

enum UnitStatus {
  AVAILABLE
  HELD
  BOOKED
  SOLD
  BLOCKED
}

enum BookingStatus {
  TENTATIVE
  CONFIRMED
  AGREEMENT
  REGISTERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  RECEIVED
  CLOSED
  CANCELLED
}

enum MaterialRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ORDERED
  DELIVERED
  CLOSED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalEntity {
  MATERIAL_REQUEST
  PURCHASE_ORDER
  INVOICE
  VENDOR_BILL
  DOCUMENT
  DRAWING
  LEAVE
  GENERIC
}

enum FolderVisibility {
  PRIVATE
  DEPARTMENT
  PROJECT
  ORGANIZATION
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum DocPermLevel {
  VIEW
  COMMENT
  EDIT
  MANAGE
}

enum EventType {
  MEETING
  SITE_VISIT
  DEADLINE
  TASK
  HOLIDAY
  MILESTONE
  REMINDER
}

enum AttendeeResponse {
  NEEDS_ACTION
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  COMMENT
  MENTION
  APPROVAL
  DEADLINE
  MEETING
  DOCUMENT
  MATERIAL_REQUEST
  ANNOUNCEMENT
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  UPLOAD
  DOWNLOAD
  PASSWORD_CHANGE
  ROLE_CHANGE
  PERMISSION_CHANGE
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  EXPORT
  VIEW
  IMPERSONATE
}

enum EmailStatus {
  DRAFT
  QUEUED
  SENT
  FAILED
}

// ─── Organization ───────────────────────────────────────────────────────────

model Project {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String?
  address     String?
  city        String    @default("Bangalore")
  latitude    Float?
  longitude   Float?
  reraNumber  String?
  isActive    Boolean   @default(true)
  startedAt   DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  floorPlans       FloorPlan[]        @relation("ProjectFloorPlans")
  memberships      ProjectMembership[]
  units            Unit[]
  tasks            Task[]
  leads            Lead[]
  folders          Folder[]
  materialRequests MaterialRequest[]
  invoices         Invoice[]
  purchaseOrders   PurchaseOrder[]
  events           CalendarEvent[]
  announcements    Announcement[]

  // v1.1
  campaigns Campaign[]
  leases    Lease[]
  drawings  Drawing[]
  rfis      RFI[]
  issues    IssueLog[]

  @@index([isActive])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String? // hex accent for UI grouping
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headId String?
  head   User?   @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)

  // Two-level structure: a division and the teams inside it.
  parentId String?
  parent   Department?  @relation("DeptTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DeptTree")

  users            User[]             @relation("UserDepartment")
  tasks            Task[]
  materialRequests MaterialRequest[]
  folderPerms      FolderPermission[]
  announcements    Announcement[]

  @@index([isActive])
}

model User {
  id           String     @id @default(cuid())
  name         String
  username     String     @unique
  email        String     @unique
  phone        String?
  employeeId   String?    @unique
  designation  String?
  passwordHash String
  role         RoleName   @default(EMPLOYEE)
  status       UserStatus @default(INVITED)
  avatarUrl    String?
  joiningDate  DateTime?
  lastLoginAt  DateTime?

  // Security
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String? // AES-256-GCM encrypted TOTP secret
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  passwordChangedAt  DateTime  @default(now())
  mustChangePassword Boolean   @default(false)

  // Self-signup / access requests
  emailVerifiedAt  DateTime?
  verifyToken      String?   @unique
  verifyExpiresAt  DateTime?
  signupNote       String?
  approvedAt       DateTime?
  approvedById     String?

  departmentId String?
  department   Department? @relation("UserDepartment", fields: [departmentId], references: [id], onDelete: SetNull)

  // Reporting line. Drives who can see whose work (see lib/rbac/scope.ts).
  managerId     String?
  manager       User?   @relation("UserHierarchy", fields: [managerId], references: [id], onDelete: SetNull)
  directReports User[]  @relation("UserHierarchy")

  salesTargets    SalesTarget[]    @relation("UserTargets")
  incentiveEntries IncentiveEntry[] @relation("UserIncentives")
  attendance       Attendance[]     @relation("UserAttendance")
  dutyRoster       DutyRoster[]     @relation("UserRoster")
  socialAccounts   UserSocialAccount[] @relation("UserSocials")

  /** Personal WhatsApp number used for click-to-chat from the CRM. */
  whatsappNumber String?

  /** Personal sidebar layout: { pinned: string[], order: string[], hidden: string[] } */
  navPrefs Json?

  // Security
  twoFactorGraceUntil DateTime? // must enrol before this date
  allowForeignAccess  Boolean   @default(false) // may sign in from outside the allowed countries
  lastCountry         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Back-relations
  headedDepartments   Department[]         @relation("DepartmentHead")
  projectMemberships  ProjectMembership[]
  sessions            Session[]
  backupCodes         BackupCode[]
  loginHistory        LoginHistory[]
  trustedDevices      TrustedDevice[]
  passwordHistory     PasswordHistory[]
  webauthnCredentials WebAuthnCredential[]
  permissionOverrides UserPermission[]

  createdTasks    Task[]         @relation("TaskCreatedBy")
  taskAssignments TaskAssignee[]
  taskWatching    TaskWatcher[]
  taskComments    TaskComment[]
  taskActivities  TaskActivity[]

  ownedLeads     Lead[]         @relation("LeadOwner")
  leadActivities LeadActivity[]
  salesBookings  Booking[]      @relation("BookingSalesRep")

  uploadedFiles     FileObject[]       @relation("FileUploadedBy")
  ownedDocuments    Document[]         @relation("DocumentOwner")
  documentVersions  DocumentVersion[]
  createdFolders    Folder[]           @relation("FolderCreatedBy")
  folderPermissions FolderPermission[]

  createdInvoices    Invoice[]         @relation("InvoiceCreatedBy")
  createdPOs         PurchaseOrder[]   @relation("POCreatedBy")
  createdVendorBills VendorBill[]      @relation("VendorBillCreatedBy")
  materialRequests   MaterialRequest[] @relation("MRRequester")

  approvalsRequested ApprovalRequest[] @relation("ApprovalRequester")
  approvalDecisions  ApprovalStep[]    @relation("ApprovalApprover")

  emailsSent       EmailMessage[]  @relation("EmailFrom")
  organizedEvents  CalendarEvent[] @relation("EventOrganizer")
  eventAttendances EventAttendee[]

  notifications     Notification[]
  notificationPrefs NotificationPreference[]
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]
  announcements     Announcement[]           @relation("AnnouncementAuthor")

  // Marketing / Lease / Architecture (v1.1)
  ownedCampaigns      Campaign[]           @relation("CampaignOwner")
  marketingAssets     MarketingAsset[]     @relation("MarketingAssetCreatedBy")
  socialPosts         SocialPost[]         @relation("SocialPostCreatedBy")
  managedLeases       Lease[]              @relation("LeaseManager")
  reportedMaintenance MaintenanceRequest[] @relation("MaintenanceReporter")
  assignedMaintenance MaintenanceRequest[] @relation("MaintenanceAssignee")
  createdDrawings     Drawing[]            @relation("DrawingCreatedBy")
  drawingRevisions    DrawingRevision[]    @relation("DrawingRevisionCreatedBy")
  raisedRfis          RFI[]                @relation("RFIRaisedBy")
  assignedRfis        RFI[]                @relation("RFIAssignee")
  raisedIssues        IssueLog[]           @relation("IssueRaisedBy")
  assignedIssues      IssueLog[]           @relation("IssueAssignee")

  @@index([status])
  @@index([departmentId])
  @@index([role])
}

model ProjectMembership {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}

// ─── RBAC ───────────────────────────────────────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "task.create", "billing.invoice.approve"
  module      String // e.g. "task", "billing"
  description String?
  createdAt   DateTime @default(now())

  roles         RolePermission[]
  userOverrides UserPermission[]

  @@index([module])
}

model RolePermission {
  id           String           @id @default(cuid())
  role         RoleName
  permissionId String
  effect       PermissionEffect @default(ALLOW)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

model UserPermission {
  id           String           @id @default(cuid())
  userId       String
  permissionId String
  effect       PermissionEffect @default(ALLOW)
  createdAt    DateTime         @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

// ─── Auth & security ────────────────────────────────────────────────────────

model Session {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique // SHA-256 of the opaque session token
  ipAddress    String?
  userAgent    String?
  deviceLabel  String?
  createdAt    DateTime  @default(now())
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String // bcrypt hash of a one-time backup code
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  deviceHash String   @unique // hash of device fingerprint cookie
  label      String?
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  ipAddress   String?
  country     String?
  userAgent   String?
  approvedAt  DateTime  @default(now())
  revokedAt   DateTime?
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique
  publicKey    String
  counter      Int      @default(0)
  transports   String?
  label        String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String?
  username  String? // captured even on failure (unknown user)
  success   Boolean
  reason    String? // e.g. "bad_password", "locked", "2fa_failed"
  ipAddress String?
  userAgent String?
  city      String?
  country   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Files & Document Management ─────────────────────────────────────────────

model FileObject {
  id           String   @id @default(cuid())
  key          String   @unique // S3 object key
  bucket       String
  originalName String
  mimeType     String
  size         Int
  checksum     String? // sha256
  ocrText      String? // extracted text for search (OCR-ready)
  syncState  String   @default("PENDING") // PENDING | DONE | FAILED | SKIPPED
  syncError  String?
  driveUrl     String? // Google Drive copy
  uploadedById String?
  createdAt    DateTime @default(now())

  uploadedBy User? @relation("FileUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  documentVersions DocumentVersion[]
  taskAttachments  TaskAttachment[]
  emailAttachments EmailAttachment[]

  marketingAssets  MarketingAsset[]
  drawingRevisions DrawingRevision[]

  @@index([uploadedById])
}

model Folder {
  id          String           @id @default(cuid())
  name        String
  parentId    String?
  projectId   String?
  visibility  FolderVisibility @default(DEPARTMENT)
  driveFolderId String? // the matching folder in Google Drive
  path        String           @default("/") // materialized path for fast subtree queries
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("FolderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  documents   Document[]
  permissions FolderPermission[]

  @@index([parentId])
  @@index([projectId])
  @@index([parentId, deletedAt])
}

model FolderPermission {
  id           String       @id @default(cuid())
  folderId     String
  userId       String?
  departmentId String?
  role         RoleName?
  level        DocPermLevel @default(VIEW)
  createdAt    DateTime     @default(now())

  folder     Folder      @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([folderId])
}

model Document {
  id             String    @id @default(cuid())
  title          String
  folderId       String
  ownerId        String?
  currentVersion Int       @default(1)
  status         String    @default("ACTIVE") // ACTIVE | ARCHIVED
  expiresAt      DateTime? // expiry alerts (licenses, approvals)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  owner  User?  @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  versions DocumentVersion[]
  tags     DocumentTag[]

  @@index([folderId])
  @@index([expiresAt])
  @@index([folderId, deletedAt])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     Int
  fileId      String
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file      FileObject @relation(fields: [fileId], references: [id], onDelete: Restrict)
  createdBy User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([documentId, version])
  @@index([fileId])
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  documents DocumentTag[]
}

model DocumentTag {
  documentId String
  tagId      String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
}

// ─── Tasks & Work Assignment ────────────────────────────────────────────────

model Task {
  id           String     @id @default(cuid())
  reference    String     @unique // human key e.g. TSK-1042
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  priority     Priority   @default(MEDIUM)
  projectId    String?
  departmentId String?
  createdById  String
  parentId     String? // subtask support
  dueDate      DateTime?
  remindAt     DateTime?
  startDate    DateTime?
  estimateMins Int?
  actualMins   Int?
  position     Int        @default(0) // Kanban ordering within a status column
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy  User        @relation("TaskCreatedBy", fields: [createdById], references: [id])
  parent     Task?       @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks   Task[]      @relation("TaskSubtasks")

  assignees      TaskAssignee[]
  watchers       TaskWatcher[]
  comments       TaskComment[]
  checklistItems ChecklistItem[]
  attachments    TaskAttachment[]
  labels         TaskLabelOnTask[]
  activities     TaskActivity[]
  dependsOn      TaskDependency[]  @relation("DependsOn")
  dependencyFor  TaskDependency[]  @relation("DependencyFor")

  @@index([status])
  @@index([projectId])
  @@index([departmentId])
  @@index([dueDate])
  @@index([createdById])
}

model TaskAssignee {
  id          String        @id @default(cuid())
  taskId      String
  userId      String
  state       AssigneeState @default(ASSIGNED)
  reason      String? // rejection / clarification note
  respondedAt DateTime?
  progressPct Int           @default(0)
  createdAt   DateTime      @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskWatcher {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model ChecklistItem {
  id          String   @id @default(cuid())
  taskId      String
  text        String
  isDone      Boolean  @default(false)
  isMilestone Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskComment {
  id        String    @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  mentions  String[] // userIds mentioned
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  fileId    String
  createdAt DateTime @default(now())

  task Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskLabel {
  id    String            @id @default(cuid())
  name  String            @unique
  color String            @default("#A07D34")
  tasks TaskLabelOnTask[]
}

model TaskLabelOnTask {
  taskId  String
  labelId String
  task    Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model TaskDependency {
  id          String   @id @default(cuid())
  taskId      String // this task ...
  dependsOnId String // ... depends on that task
  createdAt   DateTime @default(now())

  task      Task @relation("DependsOn", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("DependencyFor", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
}

model TaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  actorId   String?
  action    String // created | status_changed | assigned | commented | ...
  meta      Json?
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId])
}

// ─── Sales, Leads, NRI, Bookings, Inventory ─────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  reference    String     @unique // LEAD-2044
  name         String
  email        String?
  phone        String?
  source       LeadSource @default(WEBSITE)
  status       LeadStatus @default(NEW)
  score        Int        @default(0)
  temperature  LeadTemperature @default(WARM)
  budgetMin    Decimal?   @db.Decimal(14, 2)
  budgetMax    Decimal?   @db.Decimal(14, 2)
  requirement  String?
  projectId    String?
  ownerId      String?
  // NRI-specific
  isNri        Boolean    @default(false)
  country      String?
  timezone     String?
  nextFollowUp DateTime?
  lostReason   String?
  locality     String? // for the lead map / heat-map
  latitude     Float?
  longitude    Float?
  consentAt    DateTime? // DPDP: when this person agreed to be contacted
  consentSource String?
  channelPartnerId String? // broker who owns this lead
  cpLockedUntil    DateTime? // commission-protection lock window
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  customFields Json? // admin-defined custom field values

  project    Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  owner      User?          @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities LeadActivity[]
  bookings   Booking[]

  @@index([status])
  @@index([ownerId])
  @@index([isNri])
  @@index([nextFollowUp])
  @@index([status, ownerId])
}

model LeadActivity {
  id          String           @id @default(cuid())
  leadId      String
  userId      String?
  type        LeadActivityType
  subject     String?
  notes       String?
  outcome     String?
  scheduledAt DateTime?
  occurredAt  DateTime         @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
}

model Unit {
  id             String     @id @default(cuid())
  projectId      String
  code           String // e.g. A-1203
  tower          String?
  floor          Int?
  typology       String? // 2BHK / 3BHK / Penthouse
  carpetAreaSqft Decimal?   @db.Decimal(10, 2)
  price          Decimal?   @db.Decimal(14, 2)
  status         UnitStatus @default(AVAILABLE)
  facing         String? // N / E / S / W etc.
  holdUntil      DateTime? // auto-release deadline while HELD
  heldForLeadId  String? // lead the unit is blocked for
  heldById       String? // rep who placed the hold
  tokenAmount    Decimal?   @db.Decimal(14, 2)
  holdNote       String?
  customFields   Json? // admin-defined custom field values
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bookings Booking[]
  pins     UnitPin[] @relation("UnitPins")

  leases      Lease[]
  maintenance MaintenanceRequest[]

  @@unique([projectId, code])
  @@index([status])
  @@index([projectId, status])
}

model Booking {
  id             String        @id @default(cuid())
  reference      String        @unique // BKG-3001
  leadId         String?
  unitId         String?
  salesRepId     String?
  status         BookingStatus @default(TENTATIVE)
  paymentStatus  PaymentStatus @default(PENDING)
  agreementValue Decimal?      @db.Decimal(14, 2)
  cancelledAt    DateTime?
  cancelReason   String?
  forfeitAmount  Decimal?      @db.Decimal(14, 2)
  refundAmount   Decimal?      @db.Decimal(14, 2)
  bookedAt       DateTime      @default(now())
  customFields Json? // admin-defined custom field values
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  lead     Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  unit     Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  salesRep User?              @relation("BookingSalesRep", fields: [salesRepId], references: [id], onDelete: SetNull)
  payments PaymentMilestone[]

  @@index([status])
  @@index([bookedAt])
}

model PaymentMilestone {
  id        String        @id @default(cuid())
  bookingId String
  label     String
  amount    Decimal       @db.Decimal(14, 2)
  dueDate   DateTime?
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([dueDate])
  @@index([status])
}

// ─── Billing ────────────────────────────────────────────────────────────────

model Vendor {
  id        String   @id @default(cuid())
  name      String
  gstin     String?
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  vendorBills    VendorBill[]

  @@index([isActive])
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique // INV-2026-0001
  projectId   String?
  clientName  String
  clientGstin String?
  status      InvoiceStatus @default(DRAFT)
  issueDate   DateTime      @default(now())
  dueDate     DateTime?
  subTotal    Decimal       @default(0) @db.Decimal(14, 2)
  cgst        Decimal       @default(0) @db.Decimal(14, 2)
  sgst        Decimal       @default(0) @db.Decimal(14, 2)
  igst        Decimal       @default(0) @db.Decimal(14, 2)
  total       Decimal       @default(0) @db.Decimal(14, 2)
  amountPaid  Decimal       @default(0) @db.Decimal(14, 2)
  notes       String?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project   Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User?         @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     InvoiceItem[]

  @@index([status])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  hsnSac      String?
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  rate        Decimal @default(0) @db.Decimal(14, 2)
  gstRate     Decimal @default(18) @db.Decimal(5, 2)
  amount      Decimal @default(0) @db.Decimal(14, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PurchaseOrder {
  id          String    @id @default(cuid())
  number      String    @unique // PO-2026-0001
  projectId   String?
  vendorId    String?
  status      POStatus  @default(DRAFT)
  orderDate   DateTime  @default(now())
  expectedAt  DateTime?
  subTotal    Decimal   @default(0) @db.Decimal(14, 2)
  taxTotal    Decimal   @default(0) @db.Decimal(14, 2)
  total       Decimal   @default(0) @db.Decimal(14, 2)
  notes       String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vendor    Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("POCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     POItem[]

  @@index([status])
}

model POItem {
  id          String  @id @default(cuid())
  poId        String
  description String
  hsnSac      String?
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  unit        String  @default("nos")
  rate        Decimal @default(0) @db.Decimal(14, 2)
  gstRate     Decimal @default(18) @db.Decimal(5, 2)
  amount      Decimal @default(0) @db.Decimal(14, 2)

  po PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
}

model VendorBill {
  id          String        @id @default(cuid())
  number      String        @unique
  vendorId    String?
  amount      Decimal       @default(0) @db.Decimal(14, 2)
  gstAmount   Decimal       @default(0) @db.Decimal(14, 2)
  status      InvoiceStatus @default(DRAFT)
  billDate    DateTime      @default(now())
  dueDate     DateTime?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor    Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdBy User?   @relation("VendorBillCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
}

// ─── Material Requests & Internal Email ─────────────────────────────────────

model MaterialRequest {
  id           String                @id @default(cuid())
  reference    String                @unique // MR-2026-0001
  title        String
  projectId    String?
  departmentId String?
  requesterId  String
  priority     Priority              @default(MEDIUM)
  status       MaterialRequestStatus @default(DRAFT)
  neededBy     DateTime?
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  project    Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  department Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  requester  User                  @relation("MRRequester", fields: [requesterId], references: [id])
  items      MaterialRequestItem[]
  approval   ApprovalRequest?
  email      EmailMessage?

  @@index([status])
  @@index([requesterId])
}

model MaterialRequestItem {
  id        String  @id @default(cuid())
  requestId String
  material  String // Cement, Steel, Tiles ...
  quantity  Decimal @default(1) @db.Decimal(12, 2)
  unit      String  @default("nos")
  spec      String?

  request MaterialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique // material_request, welcome, approval ...
  name      String
  subject   String
  body      String // handlebars-style {{var}} placeholders
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailMessage {
  id                String      @id @default(cuid())
  fromUserId        String?
  toEmails          String[]
  ccEmails          String[]
  subject           String
  body              String
  status            EmailStatus @default(DRAFT)
  templateKey       String?
  materialRequestId String?     @unique
  sentAt            DateTime?
  error             String?
  createdAt         DateTime    @default(now())

  fromUser        User?             @relation("EmailFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  materialRequest MaterialRequest?  @relation(fields: [materialRequestId], references: [id], onDelete: SetNull)
  attachments     EmailAttachment[]

  @@index([status])
}

model EmailAttachment {
  id      String @id @default(cuid())
  emailId String
  fileId  String

  email EmailMessage @relation(fields: [emailId], references: [id], onDelete: Cascade)
  file  FileObject   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([emailId])
}

// ─── Approvals (shared workflow) ────────────────────────────────────────────

model ApprovalRequest {
  id                String         @id @default(cuid())
  entityType        ApprovalEntity
  entityId          String // polymorphic reference to the subject record
  requesterId       String
  status            ApprovalStatus @default(PENDING)
  materialRequestId String?        @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  requester       User             @relation("ApprovalRequester", fields: [requesterId], references: [id])
  materialRequest MaterialRequest? @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)
  steps           ApprovalStep[]

  @@index([entityType, entityId])
  @@index([status])
}

model ApprovalStep {
  id         String         @id @default(cuid())
  requestId  String
  approverId String
  sequence   Int            @default(1)
  status     ApprovalStatus @default(PENDING)
  comment    String?
  decidedAt  DateTime?
  createdAt  DateTime       @default(now())

  request  ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver User            @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([approverId])
}

// ─── Calendar ───────────────────────────────────────────────────────────────

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType @default(MEETING)
  projectId   String?
  organizerId String?
  location    String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  organizer User?           @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  attendees EventAttendee[]

  @@index([startAt])
  @@index([type])
}

model EventAttendee {
  eventId  String
  userId   String
  response AttendeeResponse @default(NEEDS_ACTION)

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
}

model NotificationPreference {
  id      String              @id @default(cuid())
  userId  String
  type    NotificationType
  channel NotificationChannel
  enabled Boolean             @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Announcements ──────────────────────────────────────────────────────────

model Announcement {
  id           String   @id @default(cuid())
  title        String
  body         String
  authorId     String?
  departmentId String? // null = organization-wide
  projectId    String?
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author     User?       @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([departmentId])
}

// ─── Audit & System ─────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  entityType String?
  entityId   String?
  summary    String?
  diff       Json? // { before, after } for updates
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique // branding.primary, security.passwordMinLength ...
  value     Json
  updatedAt DateTime @updatedAt
}

// ════════════════════════════════════════════════════════════════════════════
//  Marketing · Lease · Architecture  (modules v1.1)
// ════════════════════════════════════════════════════════════════════════════

enum CampaignChannel {
  META
  GOOGLE
  LINKEDIN
  YOUTUBE
  WHATSAPP
  EMAIL
  OFFLINE
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum SocialPostStatus {
  IDEA
  DRAFT
  SCHEDULED
  PUBLISHED
  CANCELLED
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRING
  RENEWED
  TERMINATED
  EXPIRED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

enum DrawingStatus {
  DRAFT
  FOR_REVIEW
  APPROVED
  SUPERSEDED
  ISSUED_FOR_CONSTRUCTION
}

enum RFIStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Marketing ──────────────────────────────────────────────────────────────

model Campaign {
  id          String          @id @default(cuid())
  name        String
  channel     CampaignChannel @default(META)
  status      CampaignStatus  @default(DRAFT)
  objective   String?
  budget      Decimal?        @db.Decimal(14, 2)
  spend       Decimal         @default(0) @db.Decimal(14, 2)
  impressions Int             @default(0)
  clicks      Int             @default(0)
  leadsCount  Int             @default(0)
  startDate   DateTime?
  endDate     DateTime?
  projectId   String?
  ownerId     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  owner   User?            @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assets  MarketingAsset[]

  @@index([status])
  @@index([channel])
}

model MarketingAsset {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("image") // image | video | brochure | document
  fileId      String?
  campaignId  String?
  tags        String[]
  createdById String?
  createdAt   DateTime @default(now())

  file      FileObject? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  campaign  Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy User?       @relation("MarketingAssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([campaignId])
}

model SocialPost {
  id          String           @id @default(cuid())
  title       String
  content     String?
  channel     CampaignChannel  @default(META)
  status      SocialPostStatus @default(IDEA)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy User? @relation("SocialPostCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([scheduledAt])
}

// ─── Lease ──────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leases Lease[]

  @@index([name])
}

model Lease {
  id               String      @id @default(cuid())
  reference        String      @unique // LSE-5001
  tenantId         String
  unitId           String?
  projectId        String?
  managerId        String?
  startDate        DateTime
  endDate          DateTime
  rentAmount       Decimal     @db.Decimal(14, 2)
  deposit          Decimal?    @db.Decimal(14, 2)
  escalationPct    Decimal?    @db.Decimal(5, 2)
  noticePeriodDays Int?
  status           LeaseStatus @default(DRAFT)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit         Unit?                @relation(fields: [unitId], references: [id], onDelete: SetNull)
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  manager      User?                @relation("LeaseManager", fields: [managerId], references: [id], onDelete: SetNull)
  rentSchedule RentScheduleItem[]
  maintenance  MaintenanceRequest[]

  @@index([status])
  @@index([endDate])
}

model RentScheduleItem {
  id      String        @id @default(cuid())
  leaseId String
  label   String
  dueDate DateTime
  amount  Decimal       @db.Decimal(14, 2)
  status  PaymentStatus @default(PENDING)
  paidAt  DateTime?

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([dueDate])
}

model MaintenanceRequest {
  id           String            @id @default(cuid())
  reference    String            @unique // MNT-6001
  title        String
  description  String?
  leaseId      String?
  unitId       String?
  priority     Priority          @default(MEDIUM)
  status       MaintenanceStatus @default(OPEN)
  reportedById String?
  assignedToId String?
  resolvedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  lease      Lease? @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  unit       Unit?  @relation(fields: [unitId], references: [id], onDelete: SetNull)
  reportedBy User?  @relation("MaintenanceReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  assignedTo User?  @relation("MaintenanceAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([status])
}

// ─── Architecture ───────────────────────────────────────────────────────────

model Consultant {
  id         String   @id @default(cuid())
  name       String
  firm       String?
  discipline String?
  email      String?
  phone      String?
  createdAt  DateTime @default(now())

  rfis RFI[]

  @@index([discipline])
}

model Drawing {
  id              String        @id @default(cuid())
  number          String // e.g. AR-101
  title           String
  discipline      String        @default("Architecture")
  projectId       String?
  status          DrawingStatus @default(DRAFT)
  currentRevision Int           @default(1)
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User?             @relation("DrawingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  revisions DrawingRevision[]

  @@index([status])
  @@index([discipline])
}

model DrawingRevision {
  id          String   @id @default(cuid())
  drawingId   String
  revision    Int
  fileId      String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  drawing   Drawing     @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  file      FileObject? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  createdBy User?       @relation("DrawingRevisionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([drawingId, revision])
}

model RFI {
  id           String    @id @default(cuid())
  number       String    @unique // RFI-7001
  subject      String
  question     String
  response     String?
  status       RFIStatus @default(OPEN)
  projectId    String?
  raisedById   String?
  assignedToId String?
  consultantId String?
  dueDate      DateTime?
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  raisedBy   User?       @relation("RFIRaisedBy", fields: [raisedById], references: [id], onDelete: SetNull)
  assignedTo User?       @relation("RFIAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  consultant Consultant? @relation(fields: [consultantId], references: [id], onDelete: SetNull)

  @@index([status])
}

model IssueLog {
  id           String        @id @default(cuid())
  title        String
  description  String?
  severity     IssueSeverity @default(MEDIUM)
  status       IssueStatus   @default(OPEN)
  projectId    String?
  raisedById   String?
  assignedToId String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  raisedBy   User?    @relation("IssueRaisedBy", fields: [raisedById], references: [id], onDelete: SetNull)
  assignedTo User?    @relation("IssueAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity])
}

// ─── Automation engine (v2.9) ───────────────────────────────────────────────

enum AutomationTrigger {
  LEAD_CREATED
  LEAD_STAGE_CHANGED
  TASK_CREATED
  TASK_STATUS_CHANGED
  SCHEDULE
}

model AutomationRule {
  id          String            @id @default(cuid())
  name        String
  description String?
  trigger     AutomationTrigger
  isActive    Boolean           @default(true)
  conditions  Json? // [{ field, op, value }]
  matchAll    Boolean           @default(true) // true = AND, false = OR
  actions     Json // [{ type, params }] — runs when conditions match
  elseActions Json? // runs when they do not
  slaMinutes  Int? // escalate if still unresolved after this long
  escalateToId String?
  runCount    Int               @default(0)
  lastRunAt   DateTime?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  runs AutomationRun[]

  @@index([trigger, isActive])
}

model AutomationRun {
  id         String   @id @default(cuid())
  ruleId     String
  entityType String?
  entityId   String?
  status     String   @default("SUCCESS") // SUCCESS | SKIPPED | FAILED
  detail     Json?
  createdAt  DateTime @default(now())

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

// ════════════════════════════════════════════════════════════════════════════
//  Channel Partner (Broker) Management  — Phase 4
// ════════════════════════════════════════════════════════════════════════════
enum ChannelPartnerStatus {
  PENDING
  APPROVED
  SUSPENDED
}
enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}
enum BrokerageStatus {
  PENDING
  INVOICED
  PAID
}

model ChannelPartner {
  id            String               @id @default(cuid())
  code          String               @unique
  firmName      String
  contactName   String
  phone         String
  email         String?
  reraNumber    String?
  panNumber     String?
  gstin         String?
  commissionPct Decimal              @default(2) @db.Decimal(5, 2)
  kycStatus     KycStatus            @default(PENDING)
  status        ChannelPartnerStatus @default(PENDING)
  bankDetails   String?
  notes         String?
  onboardedById String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([status])
}

model BrokeragePayout {
  id               String          @id @default(cuid())
  channelPartnerId String
  bookingId        String?
  leadId           String?
  grossValue       Decimal         @default(0) @db.Decimal(14, 2)
  ratePercent      Decimal         @default(0) @db.Decimal(5, 2)
  amount           Decimal         @default(0) @db.Decimal(14, 2)
  stage            String?
  status           BrokerageStatus @default(PENDING)
  dueDate          DateTime?
  paidAt           DateTime?
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([channelPartnerId])
  @@index([status])
}

// ════════════════════════════════════════════════════════════════════════════
//  Customer / Buyer Portal  — Phase 5
// ════════════════════════════════════════════════════════════════════════════
enum SnagStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  portalToken   String   @unique
  bookingId     String?
  projectId     String?
  isActive      Boolean  @default(true)
  customFields Json? // admin-defined custom field values
  onboardedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([portalToken])
}

model ConstructionUpdate {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  body        String?
  milestone   String?
  imageUrl    String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model SnagTicket {
  id           String     @id @default(cuid())
  customerId   String
  title        String
  description  String?
  category     String?
  priority     Priority   @default(MEDIUM)
  status       SnagStatus @default(OPEN)
  assignedToId String?
  resolvedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([customerId])
  @@index([status])
}

model CustomerDocument {
  id         String   @id @default(cuid())
  customerId String
  title      String
  category   String?
  url        String
  createdAt  DateTime @default(now())

  @@index([customerId])
}

// ════════════════════════════════════════════════════════════════════════════
//  Social / Marketing Integrations Hub
// ════════════════════════════════════════════════════════════════════════════
enum SocialChannel {
  WHATSAPP
  LINKEDIN
  INSTAGRAM
  FACEBOOK
  TWITTER
  YOUTUBE
  GOOGLE
  WEBSITE
  OTHER
}

model SocialActivity {
  id        String        @id @default(cuid())
  channel   SocialChannel
  kind      String        // lead | inquiry | subscriber | comment | mention | dm | follower | review
  name      String?
  handle    String?
  message   String?
  url       String?
  leadId    String?
  summary   String? // one-line AI brief shown in the notification
  notifiedAt DateTime?
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([channel])
  @@index([createdAt])
  @@index([isRead])
}

model SocialConnection {
  id          String        @id @default(cuid())
  channel     SocialChannel @unique
  isConnected Boolean       @default(false)
  label       String?
  note        String?
  connectedAt DateTime?
  updatedAt   DateTime      @updatedAt
}

// ════════════════════════════════════════════════════════════════════════════
//  Configurability + Platform Ops
// ════════════════════════════════════════════════════════════════════════════
model CustomFieldDef {
  id        String   @id @default(cuid())
  entity    String   @default("lead") // lead | unit | booking ...
  key       String
  label     String
  type      String   @default("text") // text | number | date | select | checkbox
  options   String[]
  required  Boolean  @default(false)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([entity, key])
  @@index([entity])
}

model ApiToken {
  id          String    @id @default(cuid())
  name        String
  prefix      String // first 8 chars, shown in UI
  tokenHash   String    @unique
  scopes      String[]
  createdById String?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([revokedAt])
}

model SavedView {
  id        String   @id @default(cuid())
  name      String
  entity    String // lead | booking | unit | collection
  filters   Json
  ownerId   String?
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([ownerId])
}

model Reminder {
  id          String    @id @default(cuid())
  title       String
  notes       String?
  dueAt       DateTime
  userId      String // who is reminded
  leadId      String?
  status      String    @default("PENDING") // PENDING | DONE | DISMISSED
  notifiedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  @@index([userId, status])
  @@index([dueAt])
  @@index([dueAt, status])
}

model DailyBriefing {
  id        String   @id @default(cuid())
  forDate   String   @unique // YYYY-MM-DD
  headline  String
  bullets   Json
  actions   Json
  metrics   Json
  createdAt DateTime @default(now())
}

enum PaymentRequestStatus {
  PENDING
  VIEWED
  CONFIRMED
  PAID
  CANCELLED
}

model PaymentRequest {
  id              String               @id @default(cuid())
  reference       String               @unique // PAY-1001
  token           String               @unique // unguessable public link
  payeeName       String
  payeeEmail      String?
  payeePhone      String?
  amount          Decimal              @db.Decimal(14, 2)
  description     String
  status          PaymentRequestStatus @default(PENDING)
  dueDate         DateTime?
  customerId      String?
  bookingId       String?
  requestedById   String?
  requestedByName String?
  payerReference  String? // UTR / txn reference entered by the payer
  emailSentAt     DateTime?
  viewedAt        DateTime?
  paidAt          DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status])
}

// ════════════════════════════════════════════════════════════════════════════
//  Forecasting, quotas & internal incentives  (v7.0)
// ════════════════════════════════════════════════════════════════════════════

enum TargetMetric {
  BOOKING_VALUE
  BOOKINGS
  LEADS
  SITE_VISITS
}

enum IncentiveStatus {
  ACCRUED
  APPROVED
  PAID
}

model SalesTarget {
  id          String       @id @default(cuid())
  userId      String
  periodStart DateTime
  periodEnd   DateTime
  metric      TargetMetric @default(BOOKING_VALUE)
  target      Decimal      @db.Decimal(14, 2)
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation("UserTargets", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart, metric])
  @@index([periodStart])
}

model IncentiveSlab {
  id          String   @id @default(cuid())
  name        String
  fromValue   Decimal  @default(0) @db.Decimal(14, 2)
  toValue     Decimal? @db.Decimal(14, 2)
  ratePercent Decimal  @default(0) @db.Decimal(6, 3)
  flatAmount  Decimal? @db.Decimal(14, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model IncentiveEntry {
  id          String          @id @default(cuid())
  userId      String
  bookingId   String?
  periodStart DateTime
  baseValue   Decimal         @db.Decimal(14, 2)
  amount      Decimal         @db.Decimal(14, 2)
  slabName    String?
  status      IncentiveStatus @default(ACCRUED)
  note        String?
  approvedAt  DateTime?
  paidAt      DateTime?
  createdAt   DateTime        @default(now())

  user User @relation("UserIncentives", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart])
  @@index([status])
}

// ════════════════════════════════════════════════════════════════════════════
//  E-signature  (v7.0)
// ════════════════════════════════════════════════════════════════════════════

enum SignatureStatus {
  PENDING
  VIEWED
  SIGNED
  DECLINED
  EXPIRED
}

model SignatureRequest {
  id              String          @id @default(cuid())
  reference       String          @unique
  title           String
  fileUrl         String
  signedFileUrl   String?
  entityType      String?
  entityId        String?
  requestedById   String?
  requestedByName String?
  signerName      String
  signerEmail     String?
  signerPhone     String?
  token           String          @unique
  status          SignatureStatus @default(PENDING)
  message         String?
  viewedAt        DateTime?
  signedAt        DateTime?
  declineReason   String?
  signatureData   String? // PNG data URL of the drawn signature
  signerIp        String?
  signerUserAgent String?
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
}

// ════════════════════════════════════════════════════════════════════════════
//  DPDP compliance  (v7.0)
// ════════════════════════════════════════════════════════════════════════════

enum DataRequestType {
  EXPORT
  DELETE
  CORRECTION
}

enum DataRequestStatus {
  RECEIVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model DataRequest {
  id           String            @id @default(cuid())
  reference    String            @unique
  type         DataRequestType
  status       DataRequestStatus @default(RECEIVED)
  subjectName  String
  subjectEmail String
  subjectPhone String?
  details      String?
  handledById  String?
  handledAt    DateTime?
  resultUrl    String?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status])
}

// ════════════════════════════════════════════════════════════════════════════
//  Error monitoring  (v7.0)
// ════════════════════════════════════════════════════════════════════════════

model ErrorLog {
  id          String    @id @default(cuid())
  fingerprint String    @unique
  level       String    @default("error")
  message     String
  stack       String?
  path        String?
  userId      String?
  count       Int       @default(1)
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  resolvedAt  DateTime?
  notifiedAt  DateTime?

  @@index([lastSeenAt])
  @@index([resolvedAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  Per-person social accounts  (v7.1)
// ════════════════════════════════════════════════════════════════════════════

model UserSocialAccount {
  id          String        @id @default(cuid())
  userId      String
  channel     SocialChannel
  handle      String
  profileUrl  String?
  displayName String?
  isPrimary   Boolean       @default(false)
  isActive    Boolean       @default(true)
  notes       String?
  lastSyncAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation("UserSocials", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, handle])
  @@index([channel])
}

// ════════════════════════════════════════════════════════════════════════════
//  Overdue escalation  (v7.2)
// ════════════════════════════════════════════════════════════════════════════

/**
 * One row per (piece of work, person) that has gone past its date. Tracks when
 * each channel last fired so the escalation endpoint can be called as often as
 * you like without spamming anyone — the cadence lives here, not in the cron.
 */
model OverdueNotice {
  id        String @id @default(cuid())
  itemKey   String // e.g. task:clx123
  userId    String
  kind      String // TASK | REMINDER | APPROVAL | COLLECTION
  title     String
  dueAt     DateTime
  href      String?

  lastPushAt     DateTime?
  lastEmailAt    DateTime?
  lastWhatsappAt DateTime?
  pushCount      Int       @default(0)
  emailCount     Int       @default(0)
  whatsappQueued Boolean   @default(false)

  snoozedUntil DateTime?
  resolvedAt   DateTime?
  firstSeenAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([itemKey, userId])
  @@index([userId, resolvedAt])
  @@index([resolvedAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  Document Q&A  (v8.0)
// ════════════════════════════════════════════════════════════════════════════

/**
 * A slice of a document, with its Gemini embedding stored as a plain float
 * array. No pgvector extension needed — at this document volume, cosine
 * similarity in memory is fast enough and avoids a database dependency that
 * could block a deploy.
 */
model DocChunk {
  id           String   @id @default(cuid())
  documentId   String?
  fileObjectId String?
  title        String
  source       String? // human label shown next to an answer
  page         Int?
  ordinal      Int      @default(0)
  content      String
  embedding    Float[]
  tokens       Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([documentId])
  @@index([fileObjectId])
}

// ════════════════════════════════════════════════════════════════════════════
//  Visual floor plans  (v8.0)
// ════════════════════════════════════════════════════════════════════════════

model FloorPlan {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  tower       String?
  floor       Int?
  imageUrl    String
  imageWidth  Int      @default(1000)
  imageHeight Int      @default(700)
  isActive    Boolean  @default(true)
  kind        String   @default("FLOOR") // UNIT | FLOOR | TOWER | MASTER | AMENITY
  description String?
  shareToken  String?  @unique
  isPublic    Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project    @relation("ProjectFloorPlans", fields: [projectId], references: [id], onDelete: Cascade)
  pins    UnitPin[]

  @@index([projectId])
}

/** Where a unit sits on a plan, as a percentage box so it scales to any screen. */
model UnitPin {
  id          String   @id @default(cuid())
  floorPlanId String
  unitId      String
  x           Float // 0-100, % from left
  y           Float // 0-100, % from top
  w           Float    @default(8)
  h           Float    @default(8)
  createdAt   DateTime @default(now())

  floorPlan FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  unit      Unit      @relation("UnitPins", fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([floorPlanId, unitId])
  @@index([unitId])
}

// ════════════════════════════════════════════════════════════════════════════
//  Field operations  (v8.0)
// ════════════════════════════════════════════════════════════════════════════

enum AttendanceKind {
  CHECK_IN
  CHECK_OUT
}

model Attendance {
  id         String         @id @default(cuid())
  userId     String
  projectId  String?
  kind       AttendanceKind
  at         DateTime       @default(now())
  latitude   Float?
  longitude  Float?
  accuracyM  Float?
  distanceM  Float? // from the site, when the project has coordinates
  withinSite Boolean        @default(false)
  note       String?
  photoUrl   String?
  offline    Boolean        @default(false) // captured with no signal, synced later
  createdAt  DateTime       @default(now())

  user User @relation("UserAttendance", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, at])
  @@index([projectId, at])
}

enum ShiftKind {
  MORNING
  EVENING
  NIGHT
  FULL_DAY
  OFF
}

model DutyRoster {
  id        String    @id @default(cuid())
  userId    String
  projectId String?
  date      DateTime // day only
  shift     ShiftKind @default(FULL_DAY)
  note      String?
  createdById String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation("UserRoster", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

// ════════════════════════════════════════════════════════════════════════════
//  Onboarding  (v8.0)
// ════════════════════════════════════════════════════════════════════════════

model OnboardingStep {
  id          String    @id @default(cuid())
  userId      String
  stepKey     String
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, stepKey])
}

// ════════════════════════════════════════════════════════════════════════════
//  Two-way email  (v9.0)
//
//  EmailMessage above is the outbound queue for system mail (material requests
//  and the like). This is different: the actual conversation with a buyer,
//  both directions, threaded onto the lead.
// ════════════════════════════════════════════════════════════════════════════

enum MailDirection {
  INBOUND
  OUTBOUND
}

model MailThreadMessage {
  id          String        @id @default(cuid())
  externalId  String?       @unique // Gmail message id — a rescan never duplicates
  threadKey   String // groups one conversation
  direction   MailDirection
  fromAddress String
  toAddresses String[]
  subject     String?
  bodyText    String?
  snippet     String?
  sentAt      DateTime      @default(now())

  leadId     String?
  customerId String?
  userId     String? // whoever here sent it

  trackToken String?   @unique // open-tracking pixel
  openedAt   DateTime?
  openCount  Int       @default(0)

  enrollmentId String?
  createdAt    DateTime @default(now())

  @@index([leadId, sentAt])
  @@index([customerId, sentAt])
  @@index([threadKey])
}

// ════════════════════════════════════════════════════════════════════════════
//  Email sequences  (v9.0)
// ════════════════════════════════════════════════════════════════════════════

enum SequenceStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum EnrollmentStatus {
  RUNNING
  REPLIED
  FINISHED
  STOPPED
}

model EmailSequence {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      SequenceStatus @default(PAUSED)
  stopOnReply Boolean        @default(true)
  stopOnStage String? // exit when the lead reaches this status
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  ordinal    Int      @default(0)
  dayOffset  Int      @default(0) // days after enrolment
  subject    String
  body       String
  createdAt  DateTime @default(now())

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, ordinal])
}

model SequenceEnrollment {
  id           String           @id @default(cuid())
  sequenceId   String
  leadId       String
  status       EnrollmentStatus @default(RUNNING)
  stepsSent    Int              @default(0)
  nextStepAt   DateTime?
  enrolledById String?
  enrolledAt   DateTime         @default(now())
  endedAt      DateTime?
  endReason    String?

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([status, nextStepAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  Device approval  (v9.2)
//
//  Signing in from an unrecognised device is not enough on its own. A code is
//  emailed to the account holder and must be entered before a session exists.
//  A stolen password and a stolen phone are then both insufficient alone.
// ════════════════════════════════════════════════════════════════════════════

model DeviceApproval {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique // identifies the pending challenge
  codeHash   String // SHA-256 of the six digits emailed out
  deviceHash String // the device this would trust
  ipAddress  String?
  country    String?
  userAgent  String?
  attempts   Int       @default(0)
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  Rate limiting  (v9.5)
//
//  Counted in the database rather than in memory, because each serverless
//  instance has its own memory — an in-process counter would let an attacker
//  simply spread requests across instances.
// ════════════════════════════════════════════════════════════════════════════

model RateLimit {
  id          String   @id @default(cuid())
  bucket      String // e.g. "login:1.2.3.4" or "ingest:portal"
  windowStart DateTime
  count       Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@unique([bucket, windowStart])
  @@index([windowStart])
}
